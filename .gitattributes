# =============================================================================
# Git LFS — Track large binary files
# =============================================================================

# DNN Models
android/app/src/main/assets/dnn_denoiser/*.onnx filter=lfs diff=lfs merge=lfs -text
android/app/src/main/assets/dnn_denoiser/*.pt filter=lfs diff=lfs merge=lfs -text
android/app/src/main/assets/dnn_denoiser/*.ptl filter=lfs diff=lfs merge=lfs -text

# Native shared libraries
android/app/src/main/jniLibs/**/*.so filter=lfs diff=lfs merge=lfs -text

# libdfn3.so se versiona como blob crudo (consistente con otros .so del repo); evita objeto LFS corrupto
android/app/src/main/jniLibs/arm64-v8a/libdfn3.so -filter -diff -merge -text

# Binarios ya versionados como blob crudo en la historia; evita rechazo GH009 al pushear a repos con hook LFS estricto
android/app/src/main/jniLibs/arm64-v8a/libonnxruntime.so -filter -diff -merge -text
android/app/src/main/jniLibs/arm64-v8a/liboboe.so -filter -diff -merge -text
android/app/src/main/jniLibs/arm64-v8a/libfbjni.so -filter -diff -merge -text
android/app/src/main/jniLibs/arm64-v8a/libsherpa-onnx-jni.so -filter -diff -merge -text
android/app/src/main/assets/dnn_denoiser/gtcrn.onnx -filter -diff -merge -text
android/app/src/main/assets/dnn_denoiser/gtcrn_dual_mobile.pt -filter -diff -merge -text
android/app/src/main/assets/dnn_denoiser/gtcrn_dual_mobile.ptl -filter -diff -merge -text

android/app/src/main/assets/dfn3_onnx/denoiser_model.onnx -filter -diff -merge -text
