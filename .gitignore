# =============================================================================
# Audifon — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Flutter / Dart
# -----------------------------------------------------------------------------
.dart_tool/
.packages
.pub/
build/
*.iml
*.lock
!pubspec.lock

# -----------------------------------------------------------------------------
# Android — Gradle
# -----------------------------------------------------------------------------
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/key.properties
android/*.jks
android/*.keystore

# -----------------------------------------------------------------------------
# Android — Native (CMake / NDK build artifacts)
# -----------------------------------------------------------------------------
android/app/.cxx/
android/app/src/main/cpp/**/*.o
android/app/src/main/cpp/**/*.so
android/app/src/main/cpp/**/*.a

# -----------------------------------------------------------------------------
# Android — Oboe prefab / CMake installed libs
# -----------------------------------------------------------------------------
android/app/.cxx/**/prefab/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Flutter generated
# -----------------------------------------------------------------------------
.flutter-plugins
.flutter-plugins-dependencies

# -----------------------------------------------------------------------------
# Compiled Dart snapshots / cache
# -----------------------------------------------------------------------------
.dart_tool/
*.dill

# -----------------------------------------------------------------------------
# Large binaries (downloaded via scripts/setup.sh from GitHub Releases)
# -----------------------------------------------------------------------------
android/app/src/main/assets/dnn_denoiser/*.onnx
android/app/src/main/assets/dnn_denoiser/*.pt
android/app/src/main/assets/dnn_denoiser/*.ptl
android/app/src/main/jniLibs/

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
test_hive_temp/
coverage/
*.lcov

# -----------------------------------------------------------------------------
# OS / temp
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Python (tools/)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# -----------------------------------------------------------------------------
# Node (ai/)
# -----------------------------------------------------------------------------
node_modules/
ai/node_modules/

# -----------------------------------------------------------------------------
# Gradle wrapper (keep gradle-wrapper.jar, ignore the rest of .gradle)
# -----------------------------------------------------------------------------
!android/gradle/wrapper/gradle-wrapper.jar
